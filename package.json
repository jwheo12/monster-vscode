{
  "name": "monster-language",
  "displayName": "Monster Language",
  "description": "Syntax highlighting, snippets, hover help, and file icon support for Monster (.mnst) and Monster.toml.",
  "version": "0.2.1",
  "publisher": "monster-lang",
  "license": "MIT",
  "icon": "icons/monster-marketplace.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/BitIntx/monster-vscode"
  },
  "homepage": "https://github.com/BitIntx/monster-vscode",
  "bugs": {
    "url": "https://github.com/BitIntx/monster-vscode/issues"
  },
  "galleryBanner": {
    "color": "#ff8a1f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:monster",
    "onLanguage:monster-manifest"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "monster",
    "mnst",
    "toml",
    "manifest",
    "language",
    "vscode",
    "compiler",
    "syntax"
  ],
  "scripts": {
    "package": "npx @vscode/vsce package",
    "package:pre": "npx @vscode/vsce package --pre-release",
    "publish": "npx @vscode/vsce publish",
    "publish:pre": "npx @vscode/vsce publish --pre-release"
  },
  "contributes": {
    "languages": [
      {
        "id": "monster",
        "aliases": [
          "Monster",
          "monster"
        ],
        "extensions": [
          ".mnst"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/monster-light.svg",
          "dark": "./icons/monster-dark.svg"
        }
      },
      {
        "id": "monster-manifest",
        "aliases": [
          "Monster Manifest",
          "Monster.toml"
        ],
        "filenames": [
          "Monster.toml",
          "monster.toml"
        ],
        "configuration": "./manifest-language-configuration.json",
        "icon": {
          "light": "./icons/monster-light.svg",
          "dark": "./icons/monster-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "monster",
        "scopeName": "source.monster",
        "path": "./syntaxes/monster.tmLanguage.json"
      },
      {
        "language": "monster-manifest",
        "scopeName": "source.monster.manifest",
        "path": "./syntaxes/monster-manifest.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "monster",
        "path": "./snippets/monster.json"
      },
      {
        "language": "monster-manifest",
        "path": "./snippets/monster-manifest.json"
      }
    ]
  }
}
