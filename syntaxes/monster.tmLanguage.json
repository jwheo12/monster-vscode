{
  "scopeName": "source.monster",
  "name": "Monster",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#function-declarations"
    },
    {
      "include": "#variable-declarations"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.monster",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.monster",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.monster"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.monster"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.monster",
              "match": "\\\\[nrt\"\\\\]"
            }
          ]
        }
      ]
    },
    "function-declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.monster",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.monster"
            },
            "2": {
              "name": "entity.name.function.monster"
            }
          }
        }
      ]
    },
    "variable-declarations": {
      "patterns": [
        {
          "name": "meta.variable.definition.monster",
          "match": "\\b(let)\\s+(mut\\s+)?([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.monster"
            },
            "2": {
              "name": "storage.modifier.monster"
            },
            "3": {
              "name": "variable.other.definition.monster"
            }
          }
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.monster",
          "match": "\\b(print_i32|print_bool|print_str|print_ln_i32|print_ln_bool|print_ln_str|read_i32|len|slice)\\b(?=\\s*\\()"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.monster",
          "match": "\\b(import|extern|fn|struct|let|mut|return|if|else|while|break|continue|as)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.monster",
          "match": "\\b(i32|u8|usize|bool|str|void)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.monster",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.monster",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.call.monster",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.monster",
          "match": "==|!=|<=|>=|&&|\\|\\||->|[-+*/=<>!:]"
        }
      ]
    }
  }
}
